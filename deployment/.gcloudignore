# Upload everything except heavy local artifacts, while keeping required training data.
.gcloudignore
.git
.gitignore

# Environments and caches
venv/
.venv/
__pycache__/
*.pyc
*.pyo
.ipynb_checkpoints/

# Local build/test outputs
.verify_model/
.verify_model_highmem/
logs/
models/
notebooks/

# Default data exclusions
/data/raw/**
/data/processed/**
/data/difficulty_labels/**

# Re-include OCR training data to bake into training image
!/data/
!/data/raw/
!/data/raw/iam/
!/data/raw/iam/**
!/data/processed/
!/data/processed/**
!/data/dictionaries/
!/data/dictionaries/**
