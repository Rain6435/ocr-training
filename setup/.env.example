# OCR Pipeline Configuration
OCR_PREPROCESS_DESKEW=true
OCR_PREPROCESS_DENOISE_METHOD=nlm
OCR_PREPROCESS_BINARIZE_METHOD=sauvola
OCR_PREPROCESS_TARGET_HEIGHT=64

OCR_CLASSIFIER_MODEL_PATH=models/classifier/best_model.keras
OCR_CLASSIFIER_INPUT_SIZE=128

OCR_OCR_MODEL_PATH=models/ocr_custom/best_model.keras
OCR_OCR_TFLITE_PATH=models/ocr_tflite/ocr_model.tflite
OCR_OCR_USE_TFLITE=false
OCR_OCR_IMG_HEIGHT=64
OCR_OCR_IMG_WIDTH=256
OCR_OCR_BEAM_WIDTH=10

OCR_ROUTING_EASY_THRESHOLD=0.7
OCR_ROUTING_HARD_THRESHOLD=0.6
OCR_ROUTING_ESCALATION_THRESHOLD=0.5

OCR_TROCR_MODEL_NAME=microsoft/trocr-large-handwritten
OCR_PADDLEOCR_LANG=en
OCR_ENABLE_TROCR=true
OCR_ENABLE_PADDLEOCR=false

OCR_SPELL_CORRECTION_ENABLED=true

OCR_API_HOST=0.0.0.0
OCR_API_PORT=8000
